          "grammarTag": {
            "pos": "格助詞",
            "meaning": "体修"
          },
          "grammarRefId": "joshi-kaku",
          "hint": "格助詞「の」(連体修飾): 「〜の」。「この男」=「この男」。指示語+の+体言の基本パターン"
        },
        {
