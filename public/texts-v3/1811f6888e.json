  "learningPoints": {
    "overview": [
      "随想的章段は清少納言の独自の美意識（「をかし」の精神）を表現する章段で、枕草子の真骨頂",
      "「をかし」は知的・理性的な趣を、「あはれ」はしみじみとした情趣を表し、両者が本段で共存している",
      "本段は自然描写と人物描写の二部構成で、「自然の中の美」と「人の美」を並置する清少納言特有の構成法",
      "平安時代の女性の髪は重要な美の要素で、風に乱れた髪の描写は絵画的な美意識を反映する"
    ],
    "byLayer": [
      {
        "layer": 2,
        "label": "助動詞",
        "keyPoint": "係り結びの強調: 「こそ〜をかしけれ」（已然形で結ぶ）で台風翌日の趣深さを強く主張する",
        "points": [
          {
            "text": "係り結びの強調: 「こそ〜をかしけれ」（已然形で結ぶ）で台風翌日の趣深さを強く主張する",
            "priority": "important"
          },
          {
            "text": "「の」の同格用法: 「いと濃き衣のうはぐもりたるに」の「の」は同格で「（衣で）つやが薄れているのに」",
            "priority": "important"
          },
          {
            "text": "「られ」の識別: 「吹き折られたる」（受身）と「寝られざりければ」（可能）の区別",
            "priority": "important"
          }
        ]
      },
      {
        "layer": 5,
        "label": "読解",
        "keyPoint": "前半の庭の描写では、荒れ果てた中にも「こまごまと吹き入れたる」風のしわざに風流を見出す逆説的な美意識を読み取る",
        "points": [
          {
            "text": "前半の庭の描写では、荒れ果てた中にも「こまごまと吹き入れたる」風のしわざに風流を見出す逆説的な美意識を読み取る",
            "priority": "important"
          },
          {
            "text": "後半の女性描写では、具体的な衣装・髪の描写から、平安時代の女性美の基準（長い黒髪、衣装の色目の調和）を理解する",
            "priority": "important"
          },
          {
            "text": "「荒かりつる風のしわざとはおぼえね」の否定表現が、自然現象への驚きと美的感動を同時に表していることを把握する",
            "priority": "important"
          },
          {
            "text": "「をかし」= 趣がある、おもしろい（知的な美的感覚。枕草子を代表する美意識）",
            "priority": "important"
          },
          {
            "text": "「めでたし」= すばらしい、見事だ（最高の賞賛を表す形容詞）",
            "priority": "important"
          },
          {
            "text": "「思はず」= 意外だ、思いがけない（現代語の「思わず」とは意味が異なる）",
            "priority": "important"
          }
        ]
      }
    ]
  },
