  "learningPoints": {
    "overview": [
      "本段は枕草子の中でも最も有名な日記的章段の一つで、教科書での出題頻度が極めて高い",
      "「くらげの骨」のしゃれは、隆家の「さらにまだ見ぬ骨のさま」という大げさな自慢を逆手に取ったもの（「見たことのない骨＝存在しない骨＝くらげの骨」）",
      "末尾の「かやうのことこそは、かたはらいたきことのうちに入れつべけれど」は、自らの機知を誇ることへの謙遜で、枕草子の執筆姿勢を示す",
      "「一つな落としそ」の発言者（女房たち）が枕草子の成立に関わる伝承を反映している"
    ],
    "byLayer": [
      {
        "layer": 2,
        "label": "助動詞",
        "keyPoint": "三方面への敬語使い分け: 定子（最高敬語）・隆家（尊敬語）・清少納言（謙譲語）の三者が登場し、敬語で主語を判定する典型教材",
        "points": [
          {
            "text": "三方面への敬語使い分け: 定子（最高敬語）・隆家（尊敬語）・清少納言（謙譲語）の三者が登場し、敬語で主語を判定する典型教材",
            "priority": "important"
          },
          {
            "text": "「なり」の識別: 「求めはべるなり」（断定）と「くらげのななり」（推定＝「なるなり」の撥音便）",
            "priority": "important"
          },
          {
            "text": "「てむ」「つべし」の強意用法: 「言にしてむ」（強意＋意志）、「入れつべけれど」（強意＋当然）",
            "priority": "important"
          }
        ]
      },
      {
        "layer": 5,
        "label": "読解",
        "keyPoint": "会話の流れ（隆家の自慢→定子の質問→隆家の誇張→清少納言の機知→隆家の賞賛）を正確に把握し、各発言の主語を敬語から特定する",
        "points": [
          {
            "text": "会話の流れ（隆家の自慢→定子の質問→隆家の誇張→清少納言の機知→隆家の賞賛）を正確に把握し、各発言の主語を敬語から特定する",
            "priority": "important"
          },
          {
            "text": "「くらげの骨」の機知が成立する論理構造（「まだ見ぬ骨＝存在しない骨」）を理解する",
            "priority": "important"
          },
          {
            "text": "末尾の自己言及的な記述が、枕草子の成立事情に関わるメタ的な記述であることを理解する",
            "priority": "important"
          },
          {
            "text": "「いみじ」= はなはだしい、すばらしい（文脈で良い意味にも悪い意味にもなる多義語）",
            "priority": "important"
          },
          {
            "text": "「おぼろけ」= ありふれた、並一通りの（否定を伴い「並大抵ではない」の意で使われることが多い）",
            "priority": "important"
          },
          {
            "text": "「かたはらいたし」= きまりが悪い、聞き苦しい（現代語にない古語として重要）",
            "priority": "important"
          }
        ]
      }
    ]
  },
