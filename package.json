{
  "name": "kobun-tan",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "demo": "tsx scripts/demo.ts",
    "check:cycles": "madge src --circular --extensions ts,tsx,js,jsx",
    "check:cycles:fail": "madge src --circular --extensions ts,tsx,js,jsx --no-spinner --no-color --warning || (echo '⚠️  Circular dependencies detected! Please fix them before committing.' && exit 1)",
    "build:match": "python scripts/match-vocab.py",
    "build:vocab": "python scripts/build-vocab-bundle.py",
    "build:examples": "python scripts/extract-examples.py",
    "build:texts-extract": "python scripts/extract-texts.py",
    "build:texts-enrich": "python scripts/enrich-texts.py",
    "build:texts": "npm run build:texts-extract && npm run build:texts-enrich",
    "build:data": "npm run build:match && npm run build:vocab && npm run build:examples && npm run build:texts"
  },
  "dependencies": {
    "kuromoji.js": "^0.1.6",
    "moji": "^0.5.1",
    "path-browserify": "^1.0.1",
    "@supabase/supabase-js": "^2.49.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.9.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "@vercel/node": "^3.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/ui": "^1.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.0.0",
    "typescript": "^5.2.2",
    "vite": "^5.4.20",
    "vite-plugin-pwa": "^1.0.3",
    "vitest": "^1.0.0"
  }
}
