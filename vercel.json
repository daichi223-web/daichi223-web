{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "data/**"
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/)[^.]*)",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/manifest.webmanifest",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/aggregateCandidates?minFreq=3&lookbackDays=7",
      "schedule": "0 18 * * *"
    }
  ]
}
